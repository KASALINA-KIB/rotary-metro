{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "aider-env/**",
      ".zencoder/**",
      ".zenflow/**",
      "**/*.exe",
      "**/*.pyc",
      "__pycache__/**"
    ],
    "rewrites": [
      { "source": "**", "destination": "/portfolio.html" }
    ]
  }
}
